# Ports (Internal Docker Network Expose)
WEB_PORT=3000
API_PORT=3001
WORKER_PORT=3002

# Environment
NODE_ENV=production

# URLs (Replace with your VPS Public IP or Domain)
WEB_URL=http://your_vps_ip
API_URL=http://your_vps_ip
NEXT_PUBLIC_API_URL=http://your_vps_ip

# Database & Redis (Uses Docker host names)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/newsflow?schema=public
REDIS_URL=redis://redis:6379

# Object Storage (MinIO)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://your_vps_ip:9000
S3_REGION=us-east-1
S3_BUCKET=newsflow-bucket
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# AI Provider (Mock by default)
AI_PROVIDER=mock
GEMINI_API_KEY=

# Meta/Facebook (Mock by default)
META_PROVIDER=mock
META_APP_ID=placeholder_app_id
META_APP_SECRET=placeholder_app_secret
META_OAUTH_REDIRECT_URI=http://your_vps_ip/api/v1/integrations/facebook/callback
META_GRAPH_API_VERSION=v20.0
META_REQUIRED_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement

# Encryption Keys (AES-256-GCM)
TOKEN_ENCRYPTION_KEY_V1=z0togxk76qydfi3bjmrep2145acnsh98
TOKEN_ENCRYPTION_ACTIVE_KEY_VERSION=v1

# Phase 5: Scheduling and Notifications
SCHEDULER_ENABLED=true
SCHEDULER_SCAN_INTERVAL_SECONDS=10
SCHEDULER_BATCH_SIZE=100
SCHEDULER_LOCK_TTL_SECONDS=60
SCHEDULER_LATE_GRACE_MINUTES=30
DEFAULT_WORKSPACE_TIMEZONE=Asia/Ho_Chi_Minh
NOTIFICATIONS_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=true
EMAIL_PROVIDER=mock
EMAIL_FROM_ADDRESS=noreply@newsflow.ai
EMAIL_FROM_NAME="NewsFlow AI"
