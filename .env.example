# App configs
NODE_ENV=development
APP_NAME="NewsFlow AI"
APP_VERSION=0.1.0

# Ports
WEB_PORT=3000
API_PORT=3001
WORKER_PORT=3002

# URLs
WEB_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Databases
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/newsflow?schema=public
REDIS_URL=redis://localhost:6379

# Object Storage (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=newsflow-bucket
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Logging
LOG_LEVEL=info

# Meta / Facebook Publishing
META_PROVIDER=mock
META_APP_ID=placeholder_app_id
META_APP_SECRET=placeholder_app_secret
META_OAUTH_REDIRECT_URI=http://localhost:3001/api/v1/integrations/facebook/callback
META_GRAPH_API_VERSION=v20.0
META_REQUIRED_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement
META_REQUEST_TIMEOUT_MS=15000
META_OAUTH_STATE_TTL_SECONDS=600
META_MAX_PUBLISH_ATTEMPTS=5
META_RETRY_BASE_DELAY_MS=2000
META_RETRY_MAX_DELAY_MS=60000
META_ENABLE_PHOTO_POSTS=false

# Encryption Keys (AES-256-GCM) - 32 bytes hex encoded or random string
TOKEN_ENCRYPTION_KEY_V1=a_very_secure_32_byte_secret_key_placeholder
TOKEN_ENCRYPTION_ACTIVE_KEY_VERSION=v1

# Phase 5: Scheduling and Notifications
SCHEDULER_ENABLED=true
SCHEDULER_SCAN_INTERVAL_SECONDS=30
SCHEDULER_BATCH_SIZE=100
SCHEDULER_LOCK_TTL_SECONDS=60
SCHEDULER_LOCK_HEARTBEAT_SECONDS=20
SCHEDULER_MIN_LEAD_TIME_SECONDS=120
SCHEDULER_MAX_FUTURE_DAYS=365
SCHEDULER_LATE_GRACE_MINUTES=30
SCHEDULER_EXECUTION_DEADLINE_MINUTES=30
SCHEDULER_RECOVERY_SCAN_INTERVAL_SECONDS=60
DEFAULT_WORKSPACE_TIMEZONE=Asia/Ho_Chi_Minh
NOTIFICATIONS_ENABLED=true
NOTIFICATION_RETENTION_DAYS=180
NOTIFICATION_MAX_PAGE_SIZE=100
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_CRITICAL_BYPASS_QUIET_HOURS=true
EMAIL_PROVIDER=mock
EMAIL_FROM_ADDRESS=noreply@newsflow.ai
EMAIL_FROM_NAME="NewsFlow AI"
EMAIL_REPLY_TO=
EMAIL_REQUEST_TIMEOUT_MS=15000
EMAIL_MAX_ATTEMPTS=5
OUTBOX_ENABLED=true
OUTBOX_BATCH_SIZE=100
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_PROCESSED_RETENTION_DAYS=30

# Phase 6: Billing, Usage, Settings, Admin
BILLING_ENABLED=true
BILLING_PROVIDER=mock
BILLING_SECRET_KEY=
BILLING_WEBHOOK_SECRET=mock-billing-webhook-secret
BILLING_SUCCESS_URL=http://localhost:3000/app/default-workspace/settings/billing
BILLING_CANCEL_URL=http://localhost:3000/app/default-workspace/settings/billing
BILLING_PORTAL_RETURN_URL=http://localhost:3000/app/default-workspace/settings/billing
DEFAULT_TRIAL_DAYS=14
BILLING_GRACE_PERIOD_DAYS=7
BILLING_RECONCILIATION_ENABLED=true
BILLING_RECONCILIATION_INTERVAL_HOURS=24
SETTINGS_CACHE_TTL_SECONDS=60
SETTINGS_HISTORY_RETENTION_DAYS=730
SETTINGS_ALLOW_RUNTIME_CHANGES=true
FEATURE_FLAGS_ENABLED=true
FEATURE_FLAG_CACHE_TTL_SECONDS=30
USAGE_RESERVATION_TTL_MINUTES=30
USAGE_RECONCILIATION_INTERVAL_MINUTES=15
ADMIN_CONSOLE_ENABLED=true
SYSTEM_ANNOUNCEMENTS_ENABLED=true
WHITE_LABEL_ENABLED=true
